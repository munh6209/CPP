#include <iostream>
#include <vector>
#include <fstream>
#include <ctime>
using namespace std;

void printBoard(const vector<int>& b, int n) {
    for (int i=0;i<n*n;++i) {
        if (b[i]==0) cout << "  .";
        else cout << setw(3) << b[i];
        if ((i+1)%n==0) cout << '\n';
    }
}

int main() {
    int n = 4;
    vector<int> board(n*n);
    for (int i=0;i<n*n;++i) board[i] = (i==n*n-1)?0:i+1;
    swap(board[0], board[1]);
    int moves = 5;

    printBoard(board,n);
    cout << "게임을 파일로 저장합니다...\n";
    ofstream ofs("saved_game.txt");
    if (!ofs) { cout << "파일 열기 실패\n"; return 0; }
    ofs << n << '\n';
    for (int i=0;i<n*n;++i) {
        ofs << board[i] << (i+1==n*n?'\n':' ');
    }
    ofs << moves << '\n';
    time_t t = time(nullptr);
    ofs << t << '\n';
    ofs.close();
    cout << "저장 완료: saved_game.txt\n";
    return 0;
}
