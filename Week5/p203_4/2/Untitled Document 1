#include <iostream>
#include <vector>
#include <algorithm>
#include <random>
#include <chrono>
#include <thread>
using namespace std;

void printBoard(const vector<int>& b, int n) {
    for (int i = 0; i < n*n; ++i) {
        if (b[i] == 0) cout << "  .";
        else cout << setw(3) << b[i];
        if ((i+1)%n==0) cout << '\n';
    }
}

int findZero(const vector<int>& b) {
    for (int i=0;i<(int)b.size();++i) if (b[i]==0) return i;
    return -1;
}

bool applyMove(vector<int>& b, int n, char mv) {
    int z = findZero(b);
    int r = z / n, c = z % n;
    int nr=r, nc=c;
    if (mv=='w') nr = r-1;
    else if (mv=='s') nr = r+1;
    else if (mv=='a') nc = c-1;
    else if (mv=='d') nc = c+1;
    else return false;
    if (nr<0||nr>=n||nc<0||nc>=n) return false;
    swap(b[z], b[nr*n+nc]);
    return true;
}

int main() {
    int n=4;
    cout << "리플레이 예제 (4x4). w/a/s/d로 이동, q로 종료\n";

    vector<int> start(n*n);
    for (int i=0;i<n*n;++i) start[i] = (i==n*n-1)?0:i+1;
    random_device rd; mt19937 g(rd()); shuffle(start.begin(), start.end(), g);

    vector<int> board = start;
    vector<char> moves;

    printBoard(board,n);
    while (true) {
        char ch; cin >> ch;
        if (ch=='q') break;
        if (applyMove(board,n,ch)) {
            moves.push_back(ch);
            printBoard(board,n);
        } else {
            cout << "잘못된 이동\n";
        }
    }

    cout << "\n--- 리플레이 시작 ---\n";
    vector<int> replayBoard = start;
    printBoard(replayBoard,n);
    for (char m : moves) {
        this_thread::sleep_for(chrono::milliseconds(400));
        applyMove(replayBoard,n,m);
        printBoard(replayBoard,n);
    }
    cout << "--- 리플레이 끝 ---\n";
    return 0;
}
