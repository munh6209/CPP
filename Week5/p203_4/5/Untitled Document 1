        "A1","A2","A3","A4",
        "B1","B2","B3","B4",
        "C1","C2","C3","C4",
        "D1","D2","D3","  "
    };

    random_device rd; mt19937 g(rd());
    shuffle(pieces.begin(), pieces.end(), g);

    cout << "ASCII 그림 퍼즐 (4x4):\n";
    for (int i=0;i<n*n;++i) {
