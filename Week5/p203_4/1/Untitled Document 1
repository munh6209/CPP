#include <iostream>
#include <vector>
#include <algorithm>
#include <random>
using namespace std;

int main() {
    int n;
    cout << "퍼즐 크기 선택 (3, 4, 5): ";
    cin >> n;
    if (n < 3 || n > 5) {
        cout << "3,4,5 중 하나를 입력하세요.\n";
        return 0;
    }

    vector<int> tiles(n*n);
    for (int i = 0; i < n*n; ++i) tiles[i] = (i == n*n-1) ? 0 : i+1;

    random_device rd;
    mt19937 g(rd());
    shuffle(tiles.begin(), tiles.end(), g);

    cout << n << "x" << n << " 퍼즐 초기 상태:\n";
    for (int i = 0; i < n*n; ++i) {
        if (tiles[i] == 0) cout << "  .";
        else cout << setw(3) << tiles[i];
        if ((i+1) % n == 0) cout << '\n';
    }
    return 0;
}
