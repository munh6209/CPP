#include <iostream>
#include <vector>
#include <fstream>
#include <ctime>
using namespace std;

void printBoard(const vector<int>& b, int n) {
    for (int i=0;i<n*n;++i) {
        if (b[i]==0) cout << "  .";
        else cout << setw(3) << b[i];
        if ((i+1)%n==0) cout << '\n';
    }
}

int findZero(const vector<int>& b) {
    for (int i=0;i<(int)b.size();++i) if (b[i]==0) return i;
    return -1;
}

bool applyMove(vector<int>& b, int n, char mv) {
    int z = findZero(b);
    int r = z / n, c = z % n;
    int nr=r, nc=c;
    if (mv=='w') nr = r-1;
    else if (mv=='s') nr = r+1;
    else if (mv=='a') nc = c-1;
    else if (mv=='d') nc = c+1;
    else return false;
    if (nr<0||nr>=n||nc<0||nc>=n) return false;
    swap(b[z], b[nr*n+nc]);
    return true;
}

int main() {
    ifstream ifs("saved_game.txt");
    if (!ifs) { cout << "저장된 게임이 없습니다.\n"; return 0; }
    int n; ifs >> n;
    vector<int> board(n*n);
    for (int i=0;i<n*n;++i) ifs >> board[i];
    int moves; ifs >> moves;
    time_t saved_time; ifs >> saved_time;
    ifs.close();

    cout << "저장 시각: " << ctime(&saved_time);
    cout << "현재 불러온 시각: " << ctime(new time_t(time(nullptr)));
    cout << "현재 보드 (이동수=" << moves << "):\n";
    printBoard(board,n);

    cout << "이어서 플레이: w/a/s/d 이동, q 종료\n";
    char ch;
    while (cin >> ch) {
        if (ch=='q') break;
        if (applyMove(board,n,ch)) {
            moves++;
            printBoard(board,n);
        } else cout << "잘못된 이동\n";
    }

    ofstream ofs("saved_game.txt");
    ofs << n << '\n';
    for (int i=0;i<n*n;++i) ofs << board[i] << (i+1==n*n?'\n':' ');
    ofs << moves << '\n';
    time_t t = time(nullptr);
    ofs << t << '\n';
    ofs.close();
    cout << "게임 저장 후 종료\n";
    return 0;
}
