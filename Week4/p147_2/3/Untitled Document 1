#ifndef REVERSE_H
#define REVERSE_H

int reverse(int n);

#endif

#include "reverse.h"

int reverse(int n) {
    int result = 0;
    while (n > 0) {
        result = result * 10 + (n % 10);
        n /= 10;
    }
    return result;
}

#include <iostream>
#include "reverse.h"
using namespace std;

int main() {
    int num = 12345;
    cout << "reverse(" << num << ") = " << reverse(num) << endl;
    return 0;
}
